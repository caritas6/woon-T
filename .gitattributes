# 텍스트 파일 — 저장소는 LF, 체크아웃은 OS 기본값
* text=auto

# Python / 설정 파일
*.py    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.toml  text eol=lf
*.ini   text eol=lf
*.txt   text eol=lf
*.md    text eol=lf
*.html  text eol=lf
*.css   text eol=lf
*.json  text eol=lf

# 바이너리 — diff/merge 없음
*.pdf   binary
*.png   binary
*.jpg   binary
*.emm   binary
