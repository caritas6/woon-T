# ─── API 서버 ──────────────────────────────────────────────────────────────
# 개발: http://localhost:8000/api/v1
# 프로덕션: https://api.woon-t.com/api/v1 (Railway URL)
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# ─── Toss Payments ─────────────────────────────────────────────────────────
# 테스트 키 (https://developers.tosspayments.com > 내 개발정보)
NEXT_PUBLIC_TOSS_CLIENT_KEY=test_ck_...

# ─── Sentry (에러 모니터링) ────────────────────────────────────────────
# https://sentry.io → 새 프로젝트(Next.js) → DSN 복사
# 미설정 시 Sentry 비활성화 (localhost에서도 자동 비활성)
NEXT_PUBLIC_SENTRY_DSN=
